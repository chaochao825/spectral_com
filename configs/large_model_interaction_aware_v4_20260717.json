{
  "schema_version": "large_scale_hessian_suite.v1",
  "suite_id": "large_model_interaction_aware_v4_20260717",
  "description": "Two-stage descriptive selected-weight validation on cached Qwen2.5-3B, Llama-2-7B and Mistral-7B checkpoints. Exact serialized-byte Hessian screening retains proxy top-K allocations, validation NLL selects the endpoint, and the final test split remains untouched until selection is complete. The no-joint counterfactual is reallocated to exactly the validation-selected QSL natural artifact bytes. A same-layer interaction claim is allowed only when QSL then improves final-test NLL. These jobs do not compress complete checkpoints and are not SOTA claims.",
  "evidence_contract": {
    "current_data_window_policy": "independent train calibration, validation allocation selection, and test endpoint windows are cross-role content-disjoint",
    "protocol_manifest_interface_supported": false,
    "multi_seed_aggregation_requires_consumed_protocol_manifest": true,
    "default_evidence_role": "scalability_smoke"
  },
  "resource_policy": {
    "server": "210",
    "enforce_at_runtime": true,
    "preferred_physical_gpu": 2,
    "eligible_physical_gpus": [0, 1, 2, 3],
    "gpu_memory_threshold_mib": 1024,
    "gpu_utilization_threshold_percent": 10,
    "sample_interval_seconds": 30,
    "gate_wait_timeout_hours": 24,
    "gpu_selection": "select an eligible physical GPU after two idle samples while holding its flock",
    "launch_gate": "two consecutive 30-second samples with memory.used < 1024 MiB and utilization.gpu < 10 percent",
    "minimum_available_host_memory_gib": 128,
    "minimum_output_disk_free_gib": 100,
    "sentinel_timeout_hours": 16,
    "three_tensor_pair_timeout_hours": 72,
    "maximum_gpu_memory_mib": 77824,
    "maximum_rss_gib": 512,
    "fail_closed_events": [
      "model snapshot or resource-gate mismatch",
      "non-zero runner exit, timeout or non-finite metric",
      "calibration, validation and test role overlap",
      "validation proxy evidence leaking into final test",
      "artifact checksum, roundtrip or exact byte ledger mismatch",
      "allocator fallback, frontier coarsening or open byte ledger",
      "missing pure-S, pure-L or no-joint control",
      "proxy nested-pool dominance mismatch",
      "joint-value support without equal natural bytes and lower final-test NLL"
    ]
  },
  "artifact_retention": {
    "raw_hrc_location": "server 210 output_root only",
    "github_policy": "commit configuration, manifests, hashes, CSV/JSON/Markdown summaries, figures and bounded logs; do not commit .hrc payloads",
    "minimum_reserved_gib": 50
  },
  "output_root": "results/large_model_interaction_aware_v4_20260717",
  "runner": "scripts/run_pretrained_hessian_repair.py",
  "expected_strategies": [
    "Q",
