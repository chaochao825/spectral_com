{
  "schema_version": "large_scale_hessian_suite.v1",
  "suite_id": "large_model_method_ablation_v2_20260716",
  "description": "Staged selected-weight scalability and method-factor audit for cached Qwen2.5-3B, Llama-2-7B and Mistral-7B checkpoints. The primary method uses an exact canonical-file-byte global Q/S_OBS/L allocator. Large full-covariance tensors explicitly omit the row-block-scale baseline because its current exact solve is quadratic in input width per output row; small-model gates evaluate that baseline separately. These jobs are scalability smoke evidence, not whole-checkpoint compression claims.",
  "evidence_contract": {
    "current_data_window_policy": "content-disjoint sequential windows are shared across seed values",
    "protocol_manifest_interface_supported": false,
    "multi_seed_aggregation_requires_consumed_protocol_manifest": true,
    "default_evidence_role": "scalability_smoke"
  },
  "resource_policy": {
    "server": "210",
    "physical_gpu": 3,
    "launch_gate": "two consecutive samples with memory.used < 1024 MiB and utilization.gpu < 10 percent",
    "minimum_available_host_memory_gib": 256,
    "minimum_output_disk_free_gib": 100,
    "sentinel_timeout_hours": {
      "qwen_randomized": 2,
      "qwen_full_svd": 4,
      "seven_b_randomized": 4
    },
    "full_job_timeout_hours": 12,
    "maximum_gpu_memory_mib": 77824,
    "maximum_rss_gib": 384,
    "fail_closed_events": [
      "CUDA OOM or non-zero runner exit",
      "NaN or Inf in covariance, proxy, allocation or endpoint metrics",
      "selected tensor or calibration/evaluation token count mismatch",
      "codec checksum, roundtrip or exact Q+L cap failure",
      "global allocator fallback on a primary global_exact job",
      "no layer with simultaneously active sparse and low-rank components for a combination claim"
    ]
  },
  "artifact_retention": {
    "raw_hrc_location": "server 210 output_root only",
    "github_policy": "commit configuration, manifests, hashes, CSV/JSON/Markdown summaries, figures and bounded logs; do not commit large .hrc payloads",
    "minimum_reserved_gib": 50
  },
  "output_root": "results/large_model_method_ablation_v2_20260716",
  "runner": "scripts/run_pretrained_hessian_repair.py",
  "expected_strategies": [
    "Q",
