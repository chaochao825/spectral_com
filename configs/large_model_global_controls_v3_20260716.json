{
  "schema_version": "large_scale_hessian_suite.v1",
  "suite_id": "large_model_global_controls_v3_20260716",
  "description": "Staged descriptive selected-weight audit on cached Qwen2.5-3B, Llama-2-7B and Mistral-7B checkpoints. QSL, pure global Q+L, pure global Q+S_OBS and their per-layer no-joint union use the same canonical aggregate Q+L physical-file-byte cap. The no-joint union is nested in QSL so their Hessian-cost difference isolates admission of same-layer joint S+L candidates inside the enumerated pool. These jobs do not compress whole checkpoints and are not statistical or SOTA claims.",
  "evidence_contract": {
    "current_data_window_policy": "content-disjoint sequential windows are shared across seed values",
    "protocol_manifest_interface_supported": false,
    "multi_seed_aggregation_requires_consumed_protocol_manifest": true,
    "default_evidence_role": "scalability_smoke"
  },
  "resource_policy": {
    "server": "210",
    "enforce_at_runtime": true,
    "preferred_physical_gpu": 3,
    "eligible_physical_gpus": [0, 1, 2, 3],
    "gpu_memory_threshold_mib": 1024,
    "gpu_utilization_threshold_percent": 10,
    "sample_interval_seconds": 30,
    "gate_wait_timeout_hours": 24,
    "gpu_selection": "select any eligible physical GPU that passes the launch gate; record the selected physical index and CUDA_VISIBLE_DEVICES for every job",
    "launch_gate": "two consecutive 30-second samples with memory.used < 1024 MiB and utilization.gpu < 10 percent, rechecked while holding that physical GPU's flock",
    "minimum_available_host_memory_gib": 256,
    "minimum_output_disk_free_gib": 100,
    "sentinel_timeout_hours": 4,
    "three_tensor_pair_timeout_hours": 16,
    "maximum_gpu_memory_mib": 77824,
    "maximum_rss_gib": 384,
    "fail_closed_events": [
      "model snapshot manifest, aggregate hash or current weight tree mismatch",
      "physical GPU launch gate, CUDA visibility, timeout, peak GPU memory or child RSS mismatch",
      "non-zero runner exit or timeout",
      "non-finite required endpoint, covariance or allocator metric",
      "selected tensor or exact calibration/evaluation token mismatch",
      "artifact checksum, roundtrip, target-rate or exact shared-cap mismatch",
      "global allocator fallback, frontier coarsening or open byte ledger",
      "missing global Q+L, global Q+S_OBS or no-joint union control",
      "no-joint union does not weakly dominate both pure-control families",
      "QSL does not weakly dominate its nested no-joint union control",
      "allocator cost/natural-byte ledger differs from endpoint CSV or serialized artifact",
      "declared endpoint identity differs in artifact SHA, natural bytes or endpoint metrics"
    ]
  },
  "artifact_retention": {
    "raw_hrc_location": "server 210 output_root only",
    "github_policy": "commit configuration, manifests, hashes, CSV/JSON/Markdown summaries, figures and bounded logs; do not commit .hrc payloads",
    "minimum_reserved_gib": 50
  },
  "output_root": "results/large_model_global_controls_v3_20260716",
  "runner": "scripts/run_pretrained_hessian_repair.py",
  "expected_strategies": [
    "Q",
    "Q_global_scale",
    "Q+S",
    "Q+S_OBS",
    "Q+L",
    "Q+S_OBS_global",
    "Q+L_global",
    "Q+S_OBS_or_L_global",
    "Q+S+L_QL_budget",
    "Q+S+L_QL_budget_component_scale",
    "Q+S+L",
    "Q+S_OBS+L",
    "Q+S+L_component_scale"
  ],
  "expected_outputs": [
    "run_config.json",
    "candidate_ablation.csv",
    "strategy_endpoints.csv",
    "endpoint_window_nll.csv",
    "comfort_sweep.csv",
    "comfort_summary.csv",
    "covariance_psd_audit.csv",
    "artifact_manifest.json",
    "artifact_payloads.csv",
    "summary.md",
    "figures/pretrained_hessian_repair_probe.pdf",
    "figures/pretrained_hessian_repair_probe.png"
  ],
  "common": {
    "device": "auto",
    "svd_device": "auto",
    "torch_dtype": "float16",
    "local_files_only": true,
    "dataset": "wikitext",
    "subset": "wikitext-2-raw-v1",
    "split": "validation",
